# copy to .env and fill in your values — never commit .env to git

# trading mode: set to "1" to go live, leave "0" for paper trading
LIVE_TRADING=0

# starting bankroll in USD
INITIAL_BANKROLL=10000

# api keys — required for live mode
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=    # EIP-712 signing key for order submission
KALSHI_API_KEY=

# llm provider keys — all required for predict skill ensemble
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=               # grok
DEEPSEEK_API_KEY=
